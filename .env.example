# Copy this file to ".env" and fill in your bot token.
DISCORD_TOKEN=your-bot-token-here

# Optional: change the command prefix (default "!")
# PREFIX=!

# Optional: the Discord server (guild) ID where the private "!stats" command
# works. Right-click your server icon -> Copy Server ID (needs Developer Mode).
# Leave unset to disable the stats command everywhere.
# STATS_GUILD_ID=123456789012345678
