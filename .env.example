# Copy this file to ".env" and fill in your bot token.
DISCORD_TOKEN=your-bot-token-here

# --- Private /stats command (optional) --------------------------------------
# /stats is registered ONLY in this server and only runs for OWNER_ID.
# Get IDs with Developer Mode on: right-click server icon / your name -> Copy ID.
# STATS_GUILD_ID=123456789012345678
# OWNER_ID=123456789012345678

# --- YouTube access (optional) ----------------------------------------------
# Proxies: put one sticky session per line in proxies.txt (host:port:user:pass).
# PROXY_SCHEME selects how those lines are interpreted: "http" (default) or "socks5h".
# PROXY_SCHEME=http
# A single fallback proxy (used only if proxies.txt is empty):
# PROXY=http://USER:PASS@HOST:PORT
