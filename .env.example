# Copy this file to ".env" and fill in your bot token.
DISCORD_TOKEN=your-bot-token-here

# Optional: the Discord server (guild) ID where the private "/stats" command is
# registered + allowed. Right-click your server icon -> Copy Server ID (needs
# Developer Mode). Leave unset to disable the stats command everywhere.
# STATS_GUILD_ID=123456789012345678

# Optional: proxy for the YouTube extraction step (helps past the datacenter-IP
# bot wall). Audio still downloads over the host's own IP, so the proxy only
# carries small extraction traffic. Format: http://user:pass@host:port
# (socks5://user:pass@host:port also works). Fill from your provider's details.
# PROXY=http://USER:PASS@HOST:PORT
